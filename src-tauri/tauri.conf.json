{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "ZPRT App",
    "version": "1.0.0",
    "identifier": "com.timur.zprtapp",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://127.0.0.1:5174",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "ZPRT App",
                "width": 500,
                "height": 630,
                "minWidth": 500,
                "minHeight": 630,
                "resizable": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/icon.ico", "icons/icon.png"]
    }
}
